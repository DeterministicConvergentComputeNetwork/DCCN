{
  "name": "@dccn/dccn",
  "version": "0.1.1",
  "description": "Deterministic Convergent Compute Network — JavaScript implementation",
  "type": "module",
  "main": "./index.js",
  "exports": {
    ".": {
      "import": "./index.js",
      "require": "./dist/index.cjs"
    },
    "./core": "./core/index.js",
    "./utils": "./utils/index.js"
  },
  "bin": {
    "dccn": "./bin/dccn.js"
  },
  "files": [
    "index.js",
    "core/",
    "utils/",
    "dist/",
    "bin/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "node build.js",
    "test": "node --experimental-vm-modules node_modules/.bin/jest --passWithNoTests",
    "test:watch": "node --experimental-vm-modules node_modules/.bin/jest --watch",
    "test:coverage": "node --experimental-vm-modules node_modules/.bin/jest --coverage",
    "lint": "eslint .",
    "format": "prettier --write .",
    "prepublishOnly": "npm run build && npm run test"
  },
  "keywords": [
    "deterministic",
    "hashing",
    "event-sourcing",
    "distributed-systems",
    "cryptography",
    "content-addressing",
    "reproducible",
    "cid",
    "merkle"
  ],
  "author": "James Chapman <xhecarpenxer@gmail.com>",
  "license": "GPL-3.0-or-later",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/DeterministicConvergentComputeNetwork/DCCN.git"
  },
  "bugs": {
    "url": "https://github.com/DeterministicConvergentComputeNetwork/DCCN/issues"
  },
  "homepage": "https://github.com/DeterministicConvergentComputeNetwork/DCCN#readme",
  "devDependencies": {
    "@types/node": "^20.0.0",
    "esbuild": "^0.19.0",
    "eslint": "^8.0.0",
    "jest": "^29.0.0",
    "prettier": "^3.0.0"
  },
  "dependencies": {},
  "engines": {
    "node": ">=16.0.0"
  }
}
