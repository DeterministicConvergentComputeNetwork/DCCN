{
  "name": "dccn",
  "version": "0.1.0",
  "description": "Deterministic Convergent Compute Network - JavaScript implementation",
  "type": "module",
  "main": "./index.js",
  "exports": {
    ".": {
      "import": "./index.js",
      "require": "./dist/index.cjs"
    },
    "./core": "./core/index.js",
    "./utils": "./utils/index.js"
  },
  "files": [
    "index.js",
    "core/",
    "utils/",
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "node build.js",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "test:watch": "node --experimental-vm-modules node_modules/jest/bin/jest.js --watch",
    "test:coverage": "node --experimental-vm-modules node_modules/jest/bin/jest.js --coverage",
    "lint": "eslint .",
    "format": "prettier --write .",
    "docs": "jsdoc -c jsdoc.json",
    "prepublishOnly": "npm run build && npm run test"
  },
  "keywords": [
    "deterministic",
    "hashing",
    "event-sourcing",
    "distributed-systems",
    "cryptography",
    "content-addressing",
    "reproducible"
  ],
  "author": {
    "name": "James Chapman",
    "email": "xhecarpenxer@gmail.com"
  },
  "license": "GPL-3.0-or-later",
  "repository": {
    "type": "git",
    "url": "https://github.com/yourusername/DCCN"
  },
  "bugs": {
    "url": "https://github.com/yourusername/DCCN/issues"
  },
  "homepage": "https://github.com/yourusername/DCCN#readme",
  "devDependencies": {
    "@types/node": "^20.0.0",
    "eslint": "^8.0.0",
    "jest": "^29.0.0",
    "jsdoc": "^4.0.0",
    "prettier": "^3.0.0",
    "esbuild": "^0.19.0"
  },
  "engines": {
    "node": ">=16.0.0"
  }
}
